# Copy ke .env.local lalu sesuaikan URL WordPress Anda
# Development local contoh:
# VITE_WP_SITE_URL=http://localhost/wordpress

# Production live:
VITE_WP_SITE_URL=https://cms.trimitramulti.co.id

# Optional: custom endpoint khusus data client jika CPT tidak expose di /wp-json/wp/v2/client
# Contoh:
# VITE_WP_CLIENTS_ENDPOINT=/wp-json/custom/v1/clients
